{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Setup: Development environment",
      "type": "shell",
      "command": "./scripts/setup-dev.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Setup: Verify environment",
      "type": "shell",
      "command": "./scripts/setup-dev.sh --dry-run --skip-system-packages",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Backend: Dev server",
      "type": "shell",
      "command": "./scripts/dev-backend.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "python",
        "pattern": {
          "regexp": "$^"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Started reloader process|Will watch for changes",
          "endsPattern": "Application startup complete"
        }
      }
    },
    {
      "label": "Frontend: Dev server",
      "type": "npm",
      "script": "dev",
      "path": "frontend",
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": {
          "regexp": "$^"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE v",
          "endsPattern": "Local:.*http://localhost:5173"
        }
      }
    },
    {
      "label": "Full Stack: Dev servers",
      "dependsOrder": "parallel",
      "dependsOn": ["Backend: Dev server", "Frontend: Dev server"],
      "problemMatcher": []
    },
    {
      "label": "Check: All",
      "type": "shell",
      "command": "./scripts/check-all.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Check: Backend",
      "type": "shell",
      "command": "./scripts/check-backend.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Check: Frontend",
      "type": "npm",
      "script": "check",
      "path": "frontend",
      "group": "test",
      "problemMatcher": "$tsc"
    },
    {
      "label": "GitHub: Authenticate CLI",
      "type": "shell",
      "command": "export PATH=\"$HOME/.local/bin:$PATH\"; gh auth login --hostname github.com --git-protocol ssh --web --skip-ssh-key",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "GitHub: Configure repository",
      "type": "shell",
      "command": "./scripts/configure-github-repo.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Release: Bump patch",
      "type": "shell",
      "command": "./scripts/release-version.sh patch",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Release: Bump minor",
      "type": "shell",
      "command": "./scripts/release-version.sh minor",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Release: Bump major",
      "type": "shell",
      "command": "./scripts/release-version.sh major",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
